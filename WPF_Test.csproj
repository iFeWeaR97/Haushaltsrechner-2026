<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="pictures\background.jpg" />
    <None Remove="pictures\calculator.png" />
    <None Remove="pictures\diagram.png" />
    <None Remove="pictures\finance.png" />
    <None Remove="pictures\menu.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="OxyPlot.Core" Version="2.2.0" />
    <PackageReference Include="OxyPlot.Wpf" Version="2.2.0" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="pictures\background.jpg" />
    <Resource Include="pictures\calculator.png" />
    <Resource Include="pictures\diagram.png" />
    <Resource Include="pictures\finance.png" />
    <Resource Include="pictures\menu.png" />
  </ItemGroup>

</Project>
